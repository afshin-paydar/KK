# Broker image with config + ACL baked in at the right ownership/permissions.
# Avoids the "world readable" / "owner is not mosquitto" warnings that bind
# mounts trigger (host UID != container mosquitto UID). Certs are still mounted
# at runtime from infra/pki since they're generated by bootstrap.sh.
FROM eclipse-mosquitto:2

COPY mosquitto.conf /mosquitto/config/mosquitto.conf
COPY acl /mosquitto/config/acl

USER root
RUN chown mosquitto:mosquitto /mosquitto/config/acl /mosquitto/config/mosquitto.conf \
    && chmod 0700 /mosquitto/config/acl
USER mosquitto
