# Alibaba Cloud IDaaS (OIDC) — operator login
VITE_IDAAS_AUTHORITY=https://your-tenant.aliyunidaas.com/oauth2
VITE_IDAAS_CLIENT_ID=kk-dashboard
VITE_IDAAS_REDIRECT_URI=http://localhost:5173/callback
VITE_API_BASE=/api

# Local dev: skip OIDC login (pairs with backend DEV_AUTH=true). Never in prod.
VITE_DEV_AUTH=true
