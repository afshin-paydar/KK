# Alibaba Cloud IDaaS (OIDC) — operator login
NEXT_PUBLIC_IDAAS_AUTHORITY=https://your-tenant.aliyunidaas.com/oauth2
NEXT_PUBLIC_IDAAS_CLIENT_ID=kk-dashboard
NEXT_PUBLIC_IDAAS_REDIRECT_URI=http://localhost:5173/callback
NEXT_PUBLIC_API_BASE=/api

# Local dev: skip OIDC login (pairs with backend DEV_AUTH=true). Never in prod.
NEXT_PUBLIC_DEV_AUTH=true

# Backend host used by next.config.ts rewrites (server-side proxy for /api, /enroll).
BACKEND_URL=http://localhost:8000
