# --- Database ---
DATABASE_URL=postgresql+asyncpg://kk:kk@localhost:5432/kk

# --- Alibaba Cloud IDaaS (operator auth, OIDC) ---
IDAAS_ISSUER=https://your-tenant.aliyunidaas.com/oauth2
IDAAS_AUDIENCE=kk-dashboard
IDAAS_JWKS_URL=https://your-tenant.aliyunidaas.com/oauth2/jwks

# --- Qwen / DashScope (LLM, backend-only secret) ---
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-replace-me
QWEN_DEFAULT_MODEL=qwen-plus

# --- MQTT broker (mTLS) --- paths relative to apps/backend, certs in infra/pki
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_CA_CERT=../../infra/pki/ca-chain.pem
MQTT_CLIENT_CERT=../../infra/pki/backend.pem
MQTT_CLIENT_KEY=../../infra/pki/backend.key

# --- PKI ---
PKI_CA_CERT=../../infra/pki/intermediate-ca.pem
PKI_CA_KEY=../../infra/pki/intermediate-ca.key
PKI_DEVICE_CERT_TTL_DAYS=30

# --- App ---
ENROLLMENT_TOKEN_TTL_MINUTES=60
LOG_LEVEL=info
